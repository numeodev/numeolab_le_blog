# Fonts et assets Vite hachés — immutables
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Images publiques — long TTL
/images/*
  Cache-Control: public, max-age=604800

# Favicons — long TTL
/favicon.svg
  Cache-Control: public, max-age=604800

/favicon-96x96.png
  Cache-Control: public, max-age=604800

/favicon.ico
  Cache-Control: public, max-age=604800

/apple-touch-icon.png
  Cache-Control: public, max-age=604800

# Pages HTML — revalidation courte
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# RSS et sitemap — revalidation fréquente
/rss.xml
  Cache-Control: public, max-age=3600

/sitemap-index.xml
  Cache-Control: public, max-age=3600
