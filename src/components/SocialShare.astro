---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

const shareText = encodeURIComponent(`${title} — ${url}`);
const bskyUrl = `https://bsky.app/intent/compose?text=${shareText}`;
const mastodonUrl = `https://mastodon.social/share?text=${shareText}`;
---

<div class="social-share">
  <hr />
  <p class="social-share__label">Des réactions sur cet article ?</p>
  <div class="social-share__links">
    <a href={bskyUrl} target="_blank" rel="noopener noreferrer" class="social-share__link">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 568 501" width="18" height="18" aria-hidden="true" fill="currentColor">
        <path d="M123.121 33.664C188.241 82.553 258.281 181.68 284 234.873c25.719-53.192 95.759-152.32 160.879-201.21C491.866-1.611 568-28.906 568 57.947c0 17.346-9.945 145.713-15.778 166.555-20.275 72.453-94.155 90.933-159.875 79.748C507.222 323.8 536.444 388.708 473.333 453.677c-119.86 122.76-172.271-30.636-185.789-69.72-2.689-7.908-3.947-11.617-3.544-11.617-.403 0-1.661 3.709-3.35 11.617-13.018 39.084-65.43 192.48-185.289-69.72C31.556 388.708 60.778 323.8 175.653 304.25c-65.72 11.185-139.6-7.295-159.875-79.748C9.945 203.66 0 75.293 0 57.947 0-28.906 76.134-1.611 123.121 33.664Z"/>
      </svg>
      Discuter sur Bluesky
    </a>
    <a href={mastodonUrl} target="_blank" rel="noopener noreferrer" class="social-share__link">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 74 79" width="18" height="18" aria-hidden="true" fill="currentColor">
        <path d="M73.7014 17.4323C72.5616 9.05152 65.1774 2.4469 56.424 1.1671C54.9472 0.950843 49.3518 0.163906 36.3901 0.163906H36.2933C23.3281 0.163906 20.5465 0.950843 19.0697 1.1671C10.56 2.41145 2.78877 8.34842 0.903306 16.826C0.00299285 21.0022 -0.0939701 25.6273 0.068869 29.8578C0.298865 35.9482 0.354132 42.0322 0.91133 48.0956C1.30545 52.0703 1.9817 56.0189 2.94659 59.8978C4.72 67.1929 11.9622 73.2871 19.0726 75.7501C26.6321 78.3111 34.7975 78.7838 42.6061 77.1016C43.4563 76.9198 44.2994 76.7108 45.1342 76.4748C47.0965 75.9174 49.3126 75.2905 51.0037 74.0645C51.0271 74.0469 51.0452 74.0234 51.0572 73.9966C51.0693 73.9698 51.0748 73.9404 51.0733 73.9109V67.9608C51.0732 67.9334 51.0665 67.9064 51.0535 67.8821C51.0406 67.8578 51.0218 67.8369 50.9989 67.8212C50.976 67.8055 50.9497 67.7955 50.9222 67.7919C50.8947 67.7883 50.8667 67.7913 50.8405 67.8007C45.3197 69.7424 39.5469 70.7123 33.7489 70.6715C24.0975 70.6715 21.6438 66.0963 20.9574 64.3738C20.3823 62.7397 20.0397 61.0283 19.9404 59.2982C19.9403 59.2678 19.9474 59.2378 19.9613 59.2107C19.9752 59.1836 19.9954 59.1601 20.0201 59.1422C20.0449 59.1242 20.0736 59.1123 20.1039 59.1074C20.1342 59.1026 20.1653 59.1049 20.1945 59.1143C25.6174 60.9866 31.2966 61.9464 37.0236 61.9573C38.4055 61.9573 39.7841 61.9573 41.1627 61.9231C46.9072 61.7711 52.9949 61.4937 58.6522 60.3966C58.7936 60.3694 58.9352 60.3421 59.0585 60.3085C67.3828 58.6026 75.2543 53.5607 75.9996 41.1155C76.0268 40.6243 76.0815 35.9586 76.0815 35.4493C76.0926 33.7798 76.6157 23.8938 73.7014 17.4323ZM62.6555 45.3199H54.2442V25.9996C54.2442 21.6508 52.3186 19.4363 48.4277 19.4363C44.1787 19.4363 42.0498 22.1954 42.0498 27.6501V39.1112H33.6906V27.6501C33.6906 22.1954 31.5618 19.4363 27.3128 19.4363C23.4351 19.4363 21.4933 21.6508 21.4933 25.9996V45.3199H13.082V25.3797C13.082 21.0309 14.2205 17.5868 16.4974 15.0476C18.8439 12.5087 21.9595 11.2097 25.8639 11.2097C30.3877 11.2097 33.8258 12.8734 36.1721 16.2009L38.0898 19.2283L40.0095 16.2009C42.3557 12.8734 45.7939 11.2097 50.3175 11.2097C54.2219 11.2097 57.3375 12.5087 59.6918 15.0476C61.9686 17.5868 63.1071 21.0309 63.1071 25.3797L62.6555 45.3199Z"/>
      </svg>
      Discuter sur Mastodon
    </a>
  </div>
  <div class="kofi-support">
    <p class="social-share__label">Cet article t'a été utile ?</p>
    <a href="https://ko-fi.com/numeolab" target="_blank" rel="noopener noreferrer" class="social-share__link">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor">
        <path d="M20 3H4v10c0 2.21 1.79 4 4 4h6c2.21 0 4-1.79 4-4v-3h2c1.11 0 2-.89 2-2V5c0-1.11-.89-2-2-2zm0 5h-2V5h2v3zM4 19h16v2H4z"/>
      </svg>
      Offrir un café
    </a>
  </div>
</div>

<style>
  .social-share {
    margin-top: 3rem;
  }

  .social-share__label {
    font-size: 0.95rem;
    color: rgb(var(--color-text-muted));
    margin-bottom: 0.75rem;
  }

  .social-share__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .social-share__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: rgb(var(--color-text-muted));
    text-decoration: none;
    transition: color 0.2s;
  }

  .social-share__link:hover {
    color: rgb(var(--color-primary-400));
    text-decoration: none;
  }

  .kofi-support {
    margin-top: 1.25rem;
  }
</style>
