---
import HeaderLink from './HeaderLink.astro';
import Icon from './icons/logo.astro';
---

<header class="bg-slate-900 sticky top-0 z-50 border-b border-gray-700">
	<div
        class="container mx-auto max-w-6xl py-4 flex justify-between items-center"
      >
		<div class="flex items-center space-x-2">
			<HeaderLink href="/" showActiveIndicator={false} preserveStyle={true}>
				<Icon class="w-56 h-20"/>
			</HeaderLink>
		</div>
		<nav id="main-nav" class="hidden md:flex space-x-8" aria-label="Navigation principale">
			<HeaderLink href="/" class="hover:text-indigo-400 transition-colors" data-astro-prefetch>Accueil</HeaderLink>
			<HeaderLink href="/blog/" class="hover:text-indigo-400 transition-colors" data-astro-prefetch>Blog</HeaderLink>
			<HeaderLink href="/projets/" class="hover:text-indigo-400 transition-colors" data-astro-prefetch>Projets</HeaderLink>
			<HeaderLink href="/a-propos/" class="hover:text-indigo-400 transition-colors" data-astro-prefetch>À propos</HeaderLink>
			</nav>
		<button
			id="menu-toggle"
			class="md:hidden text-xl p-2 rounded focus:outline-none focus:ring-2 focus:ring-indigo-500"
			aria-label="Ouvrir le menu"
			aria-expanded="false"
			aria-controls="mobile-nav"
		>
			<i class="fas fa-bars" aria-hidden="true"></i>
		</button>
	</div>

	<nav
		id="mobile-nav"
		class="hidden md:hidden flex-col space-y-2 px-4 pb-4"
		aria-label="Navigation mobile"
	>
		<HeaderLink href="/" class="block py-2 hover:text-indigo-400 transition-colors" data-astro-prefetch>Accueil</HeaderLink>
		<HeaderLink href="/blog/" class="block py-2 hover:text-indigo-400 transition-colors" data-astro-prefetch>Blog</HeaderLink>
		<HeaderLink href="/projets/" class="block py-2 hover:text-indigo-400 transition-colors" data-astro-prefetch>Projets</HeaderLink>
		<HeaderLink href="/a-propos/" class="block py-2 hover:text-indigo-400 transition-colors" data-astro-prefetch>À propos</HeaderLink>
	</nav>
</header>

<script>
	const toggle = document.getElementById('menu-toggle');
	const mobileNav = document.getElementById('mobile-nav');

	toggle?.addEventListener('click', () => {
		const isOpen = mobileNav?.classList.toggle('hidden') === false;
		toggle.setAttribute('aria-expanded', String(isOpen));
		toggle.setAttribute('aria-label', isOpen ? 'Fermer le menu' : 'Ouvrir le menu');
	});
</script>
