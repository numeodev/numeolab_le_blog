---
import { getCollection } from 'astro:content';
import { POSTS_PER_PAGE } from '../directus/api';
import HeaderLink from './HeaderLink.astro';
import FormattedDate from './FormattedDate.astro';

const allEntries = await getCollection('articles');
const articles = allEntries.map((e) => e.data).slice(0, POSTS_PER_PAGE);
const total = allEntries.length;
---

<section
      class="py-16 px-4 bg-gradient-to-b from-indigo-900/20 to-transparent"
    >
      <div class="container mx-auto max-w-6xl">
        <div class="flex justify-between items-center mb-12">
          <h2 class="text-3xl font-bold text-white">Derniers articles</h2>
          {total > POSTS_PER_PAGE && (
            <HeaderLink href="/blog/" class="text-indigo-400 hover:text-indigo-300 transition-colors flex items-center">
              Voir tous les articles<i class="fas fa-arrow-right ml-2" aria-hidden="true"></i>
            </HeaderLink>
          )}
        </div>

        {articles.length === 0 ? (
          <div class="flex flex-col items-center justify-center py-16 text-center">
            <div class="w-16 h-16 mb-6 rounded-full bg-indigo-900/30 border border-indigo-700/40 flex items-center justify-center">
              <i class="fas fa-pen-nib text-2xl text-indigo-400/60" aria-hidden="true"></i>
            </div>
            <p class="text-gray-300 text-lg font-medium mb-2">Aucun article pour l'instant</p>
            <p class="text-gray-500 text-sm max-w-sm">
              Les premiers articles arrivent — revenez bientôt.
            </p>
          </div>
        ) : (
          <div class="flex flex-wrap justify-start gap-8">
            {
              articles.map((article) => (
                <article class="glass-effect rounded-xl overflow-hidden hover:border-indigo-400 transition-colors border border-gray-700 w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.33%-1.33rem)]">
                  <div class="flex flex-col min-h-64 p-6">
                    <div class="flex items-center space-x-2 mb-3">
                      {
                        article.tags.map((tag) => (
                          <span class="text-xs px-2 py-1 bg-indigo-900/50 text-indigo-300 rounded">
                            {tag}
                          </span>
                        ))
                      }
                      <span class="text-xs text-gray-400">
                        <FormattedDate date={article.publishedAt} />
                      </span>
                    </div>
                    <h3 class="text-xl font-bold mb-2">
                      {article.title}
                    </h3>
                    <p class="text-gray-300 mb-4 line-clamp-3 overflow-hidden">
                      {article.description}
                    </p>
                    <HeaderLink href={`/blog/${article.slug}/`} class="mt-auto text-indigo-400 hover:text-indigo-300 flex items-center text-sm">
                      Lire l'article <i class="fas fa-arrow-right ml-2" aria-hidden="true"></i>
                    </HeaderLink>
                  </div>
                </article>
              ))
            }
          </div>
        )}
      </div>
</section>
