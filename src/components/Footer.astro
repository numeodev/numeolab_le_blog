---
const today = new Date();
---

<footer class="pb-12 px-4">
	<div class="container mx-auto max-w-6xl">
		<div class="border-t border-gray-800 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center">
			<div class="social-links flex space-x-4">
				<a href="https://github.com/numeolab" target="_blank">
					<span class="sr-only">Voir le profil GitHub</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" astro-icon="social/github"
						><path
							fill="currentColor"
							d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
						></path></svg
					>
				</a>
				<a href="https://ko-fi.com/numeolab" target="_blank" rel="noopener noreferrer">
					<span class="sr-only">Soutenir sur Ko-fi</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32" fill="currentColor">
						<path d="M20 3H4v10c0 2.21 1.79 4 4 4h6c2.21 0 4-1.79 4-4v-3h2c1.11 0 2-.89 2-2V5c0-1.11-.89-2-2-2zm0 5h-2V5h2v3zM4 19h16v2H4z"/>
					</svg>
				</a>
				<a href="/rss.xml" target="_blank">
					<span class="sr-only">Flux RSS du blog</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" astro-icon="social/rss"
						><path
							fill="currentColor"
							d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2zm1.5 2.5c5.523 0 10 4.477 10 10a1 1 0 1 1-2 0 8 8 0 0 0-8-8 1 1 0 0 1 0-2zm0 4a6 6 0 0 1 6 6 1 1 0 1 1-2 0 4 4 0 0 0-4-4 1 1 0 0 1 0-2zm.5 7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"
						></path></svg
					>
				</a>
			</div>
			<p class="text-gray-400 text-sm mb-4 md:mb-0">
				&copy; {today.getFullYear()} Numeolab. Tous droits réservés.
			</p>
			<div class="flex space-x-6">
				<a
					href="/mentions-legales/"
					class="text-gray-400 hover:text-gray-200 transition-colors text-sm"
					>Mentions légales</a
				>
				<a
					href="/politique-de-confidentialite/"
					class="text-gray-400 hover:text-gray-200 transition-colors text-sm"
					>Politique de confidentialité</a
				>
			</div>
	  	</div>
	</div>
</footer>
