---
import type { Article } from '../directus/api';
import FormattedDate from './FormattedDate.astro';

interface Props {
  article: Article;
}

const { article } = Astro.props;
---

<li class="glass-effect rounded-xl overflow-hidden hover:border-indigo-400 transition-colors border border-gray-700">
  <a href={`/blog/${article.slug}/`} class="block h-64">
    <div class="flex flex-col h-full">
      <div class="p-6 flex flex-col h-full">
        <div class="flex items-center space-x-2 mb-3">
          {
            article.tags.map((tag) => (
              <span class="text-xs px-2 py-1 bg-indigo-900/50 text-indigo-300 rounded">
                {tag}
              </span>
            ))
          }
          <span class="text-xs text-gray-400">
            <FormattedDate date={article.publishedAt} />
          </span>
        </div>
        <h3 class="text-xl font-bold mb-2">
          {article.title}
        </h3>
        <p class="text-gray-300 mb-4 line-clamp-3 overflow-hidden text-ellipsis">
          {article.description}
        </p>
        <div class="mt-auto text-indigo-400 hover:text-indigo-300 text-sm flex items-center">
          Lire l'article <i class="fas fa-arrow-right ml-2" aria-hidden="true"></i>
        </div>
      </div>
    </div>
  </a>
</li>
