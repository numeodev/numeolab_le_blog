---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Pagination from '../../../components/Pagination.astro';
import ArticleListItem from '../../../components/ArticleListItem.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../../consts';
import { POSTS_PER_PAGE } from '../../../directus/api';
import type { Article } from '../../../directus/api';

export const getStaticPaths = (async () => {
	const allEntries = await getCollection('articles');
	const allArticles = allEntries.map((e) => e.data);
	const totalPages = Math.ceil(allArticles.length / POSTS_PER_PAGE);
	const paths = [];

	for (let i = 2; i <= totalPages; i++) {
		const start = (i - 1) * POSTS_PER_PAGE;
		const articles = allArticles.slice(start, start + POSTS_PER_PAGE);
		paths.push({
			params: { page: i.toString() },
			props: { articles, currentPage: i, totalPages },
		});
	}

	return paths;
}) satisfies GetStaticPaths;

interface Props {
	articles: Article[];
	currentPage: number;
	totalPages: number;
}

const { articles, currentPage, totalPages } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={`${SITE_TITLE} - Blog - Page ${currentPage}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="py-16 px-4 bg-gradient-to-b from-indigo-900/20 to-transparent">
				<div class="container mx-auto max-w-4xl">
					<div class="mb-8 text-center">
						<h1 class="text-3xl font-bold mb-4 gradient-text">Blog</h1>
					</div>

					<ul class="flex flex-col gap-12">
						{articles.map((article) => <ArticleListItem article={article} />)}
					</ul>

					<Pagination
						currentPage={currentPage}
						totalPages={totalPages}
						baseUrl="/blog"
					/>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
