---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SocialShare from '../components/SocialShare.astro';
import { SITE_AUTHOR, SITE_TITLE, SITE_URL, LANGUAGE } from '../consts.ts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  slug: string;
}

const { title, description, pubDate, updatedDate, heroImage, slug } = Astro.props;

const pageUrl = Astro.url.href;
const ogImage = slug ? new URL(`/og/${slug}.png`, Astro.site).href : undefined;

const blogPostingJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "url": pageUrl,
  "datePublished": pubDate instanceof Date ? pubDate.toISOString() : new Date(pubDate).toISOString(),
  "dateModified": updatedDate
    ? (updatedDate instanceof Date ? updatedDate.toISOString() : new Date(updatedDate).toISOString())
    : (pubDate instanceof Date ? pubDate.toISOString() : new Date(pubDate).toISOString()),
  "author": {
    "@type": "Person",
    "@id": `${SITE_URL}/#author`,
    "name": SITE_AUTHOR,
    "url": `${SITE_URL}/a-propos/`
  },
  "publisher": {
    "@type": "Organization",
    "@id": `${SITE_URL}/#website`,
    "name": SITE_TITLE,
    "url": SITE_URL
  },
  "inLanguage": LANGUAGE,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageUrl
  },
  ...(ogImage ? { "image": ogImage } : {})
};

---

<html lang="fr">
	<head>
		<BaseHead title={title} description={description} ogImage={ogImage} type="article" />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(blogPostingJsonLd)} />
	</head>

	<body>
		<Header />
		<main>
			<article class="blog-content mx-auto px-4 sm:px-6 py-8">
				{heroImage && (
					<div class="hero-image">
						<img
							src={heroImage}
							alt={`Image illustrant l'article : ${title}`}
							loading="eager"
							fetchpriority="high"
							class="w-full"
						/>
					</div>
				)}
				<div class="title py-4">
					<div class="date">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<div class="last-updated-on">
									Mis à jour le <FormattedDate date={updatedDate} />
								</div>
							)
						}
					</div>
					<h1>{title}</h1>
					<hr />
				</div>
				<br />
				<slot />
				<SocialShare title={title} url={pageUrl} />
			</article>
		</main>
		<Footer />
	</body>
</html>
